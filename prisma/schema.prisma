// Prisma Schema for Shree Kutch Kadwa Patidar Pandesara Mitra Mandal
// Community Management Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}


enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
  OTHER
}

// ─── Admin / Auth ────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notices   Notice[]
  events    Event[]
  auditLogs AuditLog[]

  @@map("admins")
}

// ─── Family ──────────────────────────────────────────────────────────────────

model Family {
  id               String   @id @default(cuid())
  familyId         String              // User-provided unique identifier
  businessName     String?             // Business name
  familyName       String              // Family name
  gotra            String?             // Gotra
  kutchVatan       String?             // Kutch origin
  currentCity      String?             // Current city
  businessAddress  String?             // Business address
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members Member[]

  // Composite unique constraint: familyId must be unique, businessName + familyName combination should be unique
  @@unique([familyId, businessName, familyName], name: "familyKey")
  @@index([familyId])
  @@index([familyName])
  @@index([businessName])
  @@index([kutchVatan])
  @@index([currentCity])
  @@map("families")
}

// ─── Member ──────────────────────────────────────────────────────────────────

model Member {
  id                String         @id @default(cuid())
  memberId          String         @unique
  familyId          String
  family            Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  firstName         String?
  middleName        String?
  surname           String?
  fullName          String?         @map("fullName")
  dob               DateTime?
  joinedDate        DateTime?       @map("joinedDate")
  gender            Gender
  bloodGroup        String?
  address           String?                // Member's individual address
  phone             String?                // Telephone number
  email             String?
  education         String?
  occupationRole    String?                // Occupation/Business Role
  yskId             String?                // YSK ID
  yuvaSanghFamilyId String?                // Yuva Sangh Family ID
  maritalStatus     String?                // MARRIED | UNMARRIED
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  annualFees        AnnualFee[]
  eventPayments     EventPayment[]

  @@index([familyId])
  @@index([firstName])
  @@index([surname])
  @@index([isActive])
  @@index([phone])
  @@map("members")
}

// ─── Notices ─────────────────────────────────────────────────────────────────

model Notice {
  id            String    @id @default(cuid())
  title         String
  description   String
  priority      Priority  @default(MEDIUM)
  attachmentUrl String?
  expiryDate    DateTime?
  isVisible     Boolean   @default(true)
  createdById   String
  createdBy     Admin     @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([priority])
  @@index([isVisible])
  @@index([createdAt])
  @@map("notices")
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id            String      @id @default(cuid())
  name          String
  description   String?
  date          DateTime
  venue         String?
  time          String?
  organizer     String?
  bannerUrl     String?
  isFeeRequired Boolean     @default(false)
  feeAmount     Float?
  deadline      DateTime?
  maxAttendees  Int?
  status        EventStatus @default(DRAFT)
  createdById   String
  createdBy     Admin       @relation(fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  eventPayments EventPayment[]
  gallery       GalleryImage[]

  @@index([status])
  @@index([date])
  @@map("events")
}

// ─── Membership & Fees ───────────────────────────────────────────────────────

model MembershipPlan {
  id          String   @id @default(cuid())
  year        Int      @unique
  amount      Float
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  annualFees AnnualFee[]

  @@map("membership_plans")
}

model AnnualFee {
  id            String         @id @default(cuid())
  memberId      String
  member        Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId        String
  plan          MembershipPlan @relation(fields: [planId], references: [id])
  year          Int
  dueAmount     Float
  paidAmount    Float          @default(0)
  pendingAmount Float
  status        PaymentStatus  @default(PENDING)
  paidDate      DateTime?
  paymentMode   PaymentMode?
  receiptNumber String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([memberId, year])
  @@index([year])
  @@index([status])
  @@map("annual_fees")
}

// ─── Event Payments ──────────────────────────────────────────────────────────

model EventPayment {
  id             String        @id @default(cuid())
  eventId        String
  event          Event         @relation(fields: [eventId], references: [id])
  memberId       String
  member         Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amountDue      Float
  amountPaid     Float         @default(0)
  pendingAmount  Float
  transactionRef String?
  paymentDate    DateTime?
  paymentMode    PaymentMode?
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@index([status])
  @@map("event_payments")
}

// ─── Gallery ─────────────────────────────────────────────────────────────────

model GalleryImage {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String?
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([eventId])
  @@map("gallery_images")
}

// ─── Contact Messages ────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@map("contact_messages")
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
